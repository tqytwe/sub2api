# Self-hosted deploy example (external PG/Redis). Primary prod: Zeabur — see deploy/zeabur.template.yaml
# Copy to deploy/.env on your server. Do NOT commit .env — it contains secrets.

BIND_HOST=0.0.0.0
SERVER_PORT=8206
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai

# Host PG/Redis (Docker bridge → host services)
DATABASE_HOST=172.17.0.1
DATABASE_PORT=5432
DATABASE_USER=sub2api
DATABASE_PASSWORD=change_me
DATABASE_DBNAME=sub2api
DATABASE_SSLMODE=disable

REDIS_HOST=172.17.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_DB=1

ADMIN_EMAIL=admin@sub2api.local
ADMIN_PASSWORD=change_me_on_first_deploy
JWT_SECRET=generate_with_openssl_rand_hex_32
TOTP_ENCRYPTION_KEY=

SETUP_MIGRATION_TIMEOUT_SECONDS=120
